# Copy this file to .env and fill in your values
# Never commit .env to GitHub

CLAUDE_API_KEY=your_claude_api_key_here
TEAMS_WEBHOOK_URL=your_teams_webhook_url_here

# GitHub (only needed for PR review feature)
GITHUB_TOKEN=your_github_personal_access_token

# SonarQube (only needed for sonar step)
SONAR_TOKEN=your_sonar_token
SONAR_HOST_URL=http://localhost:9000

# Pipeline context (auto-set by GitHub Actions, set manually for local testing)
REPO=BM-Ecommerce/Ecom-3d-angular
BRANCH=main
ACTOR=your_name
COMMIT_SHA=abc1234
COMMIT_MSG=Local test run
PR_NUMBER=
RUN_URL=http://localhost

# Step statuses: 0 = pass, 1 = fail
BUILD_STATUS=0
TEST_STATUS=0
SONAR_STATUS=0
